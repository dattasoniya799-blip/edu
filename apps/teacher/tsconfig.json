{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "baseUrl": ".",
    "paths": {
      "@qiming/contracts": ["../../packages/contracts/src/index.ts"],
      "@qiming/ui": ["../../packages/ui/src/index.ts"]
    },
    "types": ["vite/client"]
  },
  "include": ["src", "vite.config.ts", "tailwind.config.ts", "../../packages/contracts/src/**/*", "../../packages/ui/src/**/*", "../../packages/ui/tailwind-preset.ts"]
}
