# ---- 生产(NODE_ENV=production)启动期强制校验(src/common/env-assert.ts)----
# 以下变量生产必填,缺失/不合规则启动直接失败(fail-fast):
#   DATABASE_URL、REDIS_URL、JWT_SECRET(且不得为 dev-secret-change-me)、
#   CORS_ORIGINS(非空白名单)、UPLOAD_PUBLIC_BASE(显式设置)
DATABASE_URL="postgresql://qiming:qiming_dev@127.0.0.1:5432/qiming_dev"
REDIS_URL="redis://127.0.0.1:6379"
PORT=3000
# 生产环境必须改为强随机值(dev-secret-change-me 会被启动校验拒绝)
JWT_SECRET="dev-secret-change-me"
JWT_ACCESS_TTL="2h"
JWT_REFRESH_TTL="14d"
# 生产必填:逗号分隔的前端来源白名单;开发下留空 = 放行任意来源(生产禁止留空)
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:5175"
# 生产必填:签名/回看 URL 的对外可达 base;开发缺省回退 http://127.0.0.1:$PORT
# UPLOAD_PUBLIC_BASE="https://files.example.com"

# ---- A7 · AI 网关(openai_compatible 真实供应商适配器;C3 接 key 时只填这三项)----
# OpenAI 兼容 chat/completions 形状,不写死厂商;留空则该供应商 healthy=false,路由表默认走 mock
LLM_API_KEY=""
LLM_BASE_URL="https://api.openai.com/v1"
LLM_MODEL=""
# 课堂伴学旁白 / 学情诊断的 LLM 开关(默认模板实现,true 时经 LlmGateway 生成)
AI_COMPANION_USE_LLM="false"
AI_DIAGNOSIS_USE_LLM="false"
# AI 配置目录覆盖(提示词/审查规则/默认路由表;默认 <cwd>/src/ai/config)
# AI_CONFIG_DIR=""
