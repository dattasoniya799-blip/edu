{
  "name": "@qiming/server",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "TS_NODE_BASEURL=./dist/apps/server node -r tsconfig-paths/register dist/apps/server/src/main.js",
    "start:dev": "nest start --watch",
    "test": "jest --config test/jest-e2e.config.cjs --runInBand",
    "db:migrate": "prisma migrate dev",
    "db:apply-sql": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f prisma/migrations/0001_init/migration.sql",
    "db:seed:base": "tsx prisma/seed.ts --phase base",
    "db:import-kp": "tsx tools/import-kp.ts --org 1 --dir ../../data/knowledge-graphs",
    "db:seed:business": "tsx prisma/seed.ts --phase business",
    "loadtest": "tsx tools/loadtest/run-loadtest.ts",
    "init:prod": "tsx tools/init-prod.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^5.22.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.41.0",
    "bullmq": "^5.78.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.0",
    "nestjs-pino": "^4.1.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.0",
    "dotenv": "^17.4.2",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
