# mock 开关(opt-in,#9):仅 VITE_USE_MOCK=true 才启 MSW 拦截;
# 未设置 / 任何其它值 → 代理到真实后端(fail-safe,防生产漏配静默跑假数据)。
# 生产构建若误开 =true,启动时会 console.error+throw 拒绝(见 src/main.tsx)。
# 本地离线开发的默认 mock 已由 .env.development 提供(=true),无需在此重复。
VITE_USE_MOCK=true
# 真实后端地址(VITE_USE_MOCK!=true 时经 vite 代理 /api → 此地址;A1 改用 3200 端口时填 http://localhost:3200)
# VITE_API_TARGET=http://localhost:3000
