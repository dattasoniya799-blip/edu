# =============================================================================
# 启明智学 · 生产环境变量模板(D3)
# 复制为 deploy/.env.prod 并逐项填写:cp deploy/.env.prod.example deploy/.env.prod
# 【红线】.env.prod 含真实密钥,绝不提交仓库(deploy/.gitignore 已忽略)。
#
# 该文件双重用途:
#   1) docker compose --env-file deploy/.env.prod → 变量替换(宿主端口、POSTGRES_* 等);
#   2) server 服务 env_file → 注入后端容器。
# NODE_ENV=production 下,后端启动期强制校验(缺失/弱值直接拒绝启动,见 src/common/env-assert.ts):
#   DATABASE_URL / REDIS_URL / JWT_SECRET(拒 dev-secret-change-me)/ CORS_ORIGINS(拒空)/ UPLOAD_PUBLIC_BASE
# =============================================================================

NODE_ENV=production

# ---- PostgreSQL(compose 内网,不暴露宿主端口)----
# POSTGRES_PASSWORD 必填,生成示例:openssl rand -hex 16
# 注意:修改 POSTGRES_USER/POSTGRES_DB/POSTGRES_PASSWORD 后,下方 DATABASE_URL 必须同步改一致!
POSTGRES_USER=qiming
POSTGRES_DB=qiming
POSTGRES_PASSWORD=请改成强随机密码

# ---- 后端连接串(主机名用 compose 服务名 postgres / redis)----
DATABASE_URL=postgresql://qiming:请改成强随机密码@postgres:5432/qiming
REDIS_URL=redis://redis:6379
PORT=3000

# ---- JWT / 文件签名密钥(必填,拒绝开发默认值)----
# 生成强随机值:openssl rand -base64 48
JWT_SECRET=请用_openssl_rand_-base64_48_生成后粘贴到这里
# 令牌有效期(可选,默认 2h / 14d)
# JWT_ACCESS_TTL=2h
# JWT_REFRESH_TTL=14d

# ---- CORS 白名单(必填,拒空)----
# 写法:逗号分隔的【三个对外来源】= 师生浏览器地址栏里的 origin(协议+主机+端口,80 端口不写端口号)。
# 端口分端方案(默认):学生端 80 / 管理端 8081 / 教师端 8082,例(服务器 IP 为 192.168.1.10):
CORS_ORIGINS=http://192.168.1.10,http://192.168.1.10:8081,http://192.168.1.10:8082
# 域名方案则写:https://stu.example.com,https://admin.example.com,https://tea.example.com

# ---- 上传/回看对外 base(必填)----
# 学生端拍照直传 PUT 与教师回看签名 GET 的 URL 前缀 = 学生端对外来源(nginx 会把 /api/ 反代到后端)。
# 必须与 CORS_ORIGINS 里的学生端来源一致:
UPLOAD_PUBLIC_BASE=http://192.168.1.10

# ---- 本地文件存储(MVP 固定 local;oss 未实现,配了会启动报错)----
STORAGE_DRIVER=local
UPLOAD_ROOT=/app/storage

# ---- nginx 宿主端口(可选覆盖;默认 80/8081/8082)----
# STUDENT_HTTP_PORT=80
# ADMIN_HTTP_PORT=8081
# TEACHER_HTTP_PORT=8082

# ---- AI / LLM(可选;留空则 LLM 供应商 healthy=false,AI 路由走 mock 模板)----
# OpenAI 兼容 chat/completions 网关三件套:
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=
# 课堂伴学旁白 / 学情诊断是否走 LLM(默认模板实现)
# AI_COMPANION_USE_LLM=false
# AI_DIAGNOSIS_USE_LLM=false

# ---- 其它(可选)----
# LOG_LEVEL=info
# AUTO_MIGRATE=1        # server 启动前自动 prisma migrate deploy;置 0 改为人工执行
